  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.25",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.7.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
